
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id       String         @id @default(uuid())
  userId   String         @unique
  password String
  name     String
  // Relasi ke tabel perantara
  products UserProduct[]
}

model Product {
  id              String         @id @default(uuid())
  name            String
  serialNumber    String         @unique
  modelId         String
  image           String?
  temperature     Float          @default(0.0)
  tahunPembuatan  Int            @default(2024)
  lokasi          String         @default("Bandung, ID")
  kapasitas       String?        // Contoh: "1200 Liter"
  tipeKompresor   String?        // Contoh: "Inverter Heavy Duty"
  spesifikasiKaca String?        // Contoh: "Triple Pane Tempered"
  sistemPendingin String?        // Contoh: "Forced Air Cooling"
  materialBody    String?        // Contoh: "Stainless Steel 304"

  // Relasi ke tabel perantara
  users           UserProduct[]
}

// TABEL PERANTARA BARU (Pivot Table)
model UserProduct {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String
  product         Product  @relation(fields: [productId], references: [id])
  productId       String
  
  // Field spesifik untuk relasi ini
  status          String   @default("Aktif")
  warrantyExpiry  DateTime // Masa berlaku garansi
  serviceStatus   Boolean  @default(false)
  assignedAt      DateTime @default(now())

  @@unique([userId, productId])
}
